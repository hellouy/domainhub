# =============================================================================
# tldbi.com 环境变量清单
# =============================================================================
# 用法:复制本文件为 .env.local(本地开发)或粘贴到 Vercel 项目的
#       Settings → Environment Variables 面板(线上部署)。
#
# 【共享同一个数据库】的关键:
#   多人协作时,只要 DATABASE_URL 填成同一个值,所有人就连的是同一份数据,
#   无需任何迁移、导入导出——数据实时共享、原封不动。
#   其余密钥同理:填成和主账户相同的值即可获得完全一致的功能。
# =============================================================================


# --- 数据库(必填,共享的核心)-------------------------------------------------
# Neon Postgres 连接串。想共享同一份数据,就填与主账户完全相同的这一行。
# 从主账户的 Vercel 项目 Vars 面板复制;或从 Neon 控制台 → Connection Details 复制。
DATABASE_URL="postgres://用户名:密码@主机-pooler.区域.aws.neon.tech/数据库名?sslmode=require"


# --- 后台管理(必填)----------------------------------------------------------
# /admin 后台的登录密码,自定义任意字符串。多人共享后台请填相同值。
ADMIN_PASSWORD="设置一个后台登录密码"


# --- 汇率数据源(必填其一,建议全填以启用主备回退)-------------------------------
# 主通道:exchangerate-api.com 的 API Key(https://app.exchangerate-api.com)
EXCHANGERATE_API_KEY=""
# 备用通道:currencyfreaks.com 的 API Key(https://currencyfreaks.com)
CURRENCYFREAKS_API_KEY=""
# 说明:两者都留空时,系统自动回退到免费端点(open.er-api.com / frankfurter.dev),
#      功能不受影响,只是没有付费端点稳定。


# --- 定时爬虫 / 价格更新(可选)------------------------------------------------
# 保护 /api/cron/crawl 定时任务的密钥,自定义任意随机字符串。
# 建议用:openssl rand -base64 32 生成。不配置则该定时接口不启用鉴权保护。
CRON_SECRET=""

# 注册商凭据加密密钥。若使用「后台录入注册商 API 凭据」功能则必填,
# 且多人共享时必须填相同值,否则无法解密已保存的凭据。
# 建议用:openssl rand -base64 32 生成。
CREDENTIAL_ENCRYPTION_KEY=""


# --- AI 自动修复适配器(可选,高级功能)---------------------------------------
# 仅当使用 packages/ai-repair 的抓取规则自愈功能时需要。
# 在 v0 / Vercel 环境中 AI Gateway 多为零配置,通常无需手动填写。
AI_GATEWAY_API_KEY=""
# 可选:自定义 AI 修复使用的模型列表(逗号分隔),留空用内置默认。
AI_REPAIR_MODELS=""
